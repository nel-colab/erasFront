# Frontend Configuration
# Copy this file to .env.local and update with your local values

# Backend API Base URL (UsersService)
VITE_API_BASE_URL=http://localhost:8090
# DriveManager API Base URL (only needed when not using local containers)
VITE_DRIVE_API_BASE_URL=http://localhost:8081

# For staging, uncomment both and set to staging domain (nginx routes internally):
#VITE_API_BASE_URL=https://staging.erastcg.com
#VITE_DRIVE_API_BASE_URL=https://staging.erastcg.com

# Request timeout in milliseconds
VITE_API_TIMEOUT=30000

# Development server port (informational)
VITE_DEV_PORT=5173